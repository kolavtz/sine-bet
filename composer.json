{
  "name": "your-org/wp-r2-offload",
  "description": "WordPress plugin to automatically offload media uploads to Cloudflare R2.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "wp-phpunit/wp-phpunit": "^6.4",
    "yoast/phpunit-polyfills": "^1.1",
    "php-stubs/wordpress-stubs": "^6.4"
  },
  "autoload-dev": {
    "classmap": [
      "tests/"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml"
  },
  "extra": {
    "wordpress-stubs": {
      "functions": true,
      "classes": true,
      "constants": true
    }
  }
}